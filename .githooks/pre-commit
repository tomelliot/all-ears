#!/bin/bash
# Pre-commit hook to enforce Swift formatting standards
#
# NOTE: On a fresh clone, run the following to activate this hook:
#   git config core.hooksPath .githooks
#
# The core.hooksPath setting is local to your repository and is not
# automatically configured when cloning, so each developer must run
# the above command once after cloning.

# Get list of staged Swift files
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

# If no Swift files are staged, pass the hook
if [ -z "$STAGED_SWIFT_FILES" ]; then
  exit 0
fi

echo "Checking formatting of staged Swift files..."
echo "$STAGED_SWIFT_FILES" | xargs swift format lint --strict

if [ $? -eq 0 ]; then
  echo "All staged Swift files are properly formatted."
  exit 0
else
  echo "ERROR: Some staged Swift files are not properly formatted."
  echo "Please run: swift format --recursive daemon/Sources/ daemon/Tests/"
  echo "Then stage the changes and try committing again."
  exit 1
fi
